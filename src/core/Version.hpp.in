#ifndef VERSION_HPP
#define VERSION_HPP

// STL
#include <ctime>
#include <string_view>
#include <string>

/**
 * Some constants providing informations about version and build
 */
namespace Version {
constexpr std::string_view NAME{"Kreuzstich"};
constexpr std::string_view WEBSITE{"https://github.com/polletfa/Kreuzstich"};
constexpr int MAJOR{@PROJECT_VERSION_MAJOR@};
constexpr int MINOR{@PROJECT_VERSION_MINOR@};
constexpr std::string_view BUILD_TIME{@CMAKE_BUILD_TIMESTAMP@};
constexpr std::string_view GIT_COMMIT{"@GIT_COMMIT@"};
constexpr bool RELEASE_BUILD{
#ifdef DEBUG
    false
#else
    true
#endif
};
constexpr std::string_view LICENSE{R"(@LICENSE@)"};

/**
 * Get version string
 */
[[nodiscard]] const std::string& getVersionString();

/**
 * Replace all the variables ("$VARNAME$") with their content (in-place).
 * Variables are all the constants in Version + VERSION_STRING for the result of getVersionString
 */
std::string replaceVersionVars(std::string& str);
}

#endif // VERSION_HPP

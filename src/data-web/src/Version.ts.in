export class Version {
    static readonly NAME: string = "@CMAKE_PROJECT_NAME@";
    static readonly WEBSITE: string = "@CMAKE_PROJECT_HOMEPAGE_URL@";
    static readonly MAJOR: number = @PROJECT_VERSION_MAJOR@;
    static readonly MINOR: number = @PROJECT_VERSION_MINOR@;
    static readonly BUILD_TIME: string = "@BUILD_TIME@";
    static readonly GIT_COMMIT: string = "@GIT_COMMIT@";
    static readonly BUILD_TYPE: string = "@CMAKE_BUILD_TYPE@";
    static readonly LICENSE: string = String.raw`@LICENSE@`;

    public static getVersionString(): string {
        return `${Version.NAME} ${Version.MAJOR}.${Version.MINOR}`
            + ` ${Version.GIT_COMMIT ? Version.GIT_COMMIT.substr(0, 8) : "dev-build"}`
            + `${Version.BUILD_TYPE == "Debug" ? " debug-build" : ""}`
            + `${Version.BUILD_TIME ? " " + Version.BUILD_TIME : ""}`;
    }
};

#ifndef VERSION_HPP
#define VERSION_HPP

// STL
#include <ctime>
#include <string_view>
#include <optional>

namespace Version {
constexpr std::string_view NAME{"Kreuzstich"};
constexpr std::string_view WEBSITE{"https://github.com/polletfa/Kreuzstich"};
constexpr int MAJOR{@MAJOR@};
constexpr int MINOR{@MINOR@};
constexpr time_t BUILD_TIME{@BUILD_TIME@};
constexpr std::string_view GIT_COMMIT{"@GIT_COMMIT@"};
constexpr bool RELEASE_BUILD{@RELEASE_BUILD@};
extern const std::string VERSION_STRING;

/**
 * Replace all the variables ("$VARNAME$") with their content (in-place)
 */
std::string replaceVersionVars(std::string& str);

/**
 * Return the license text
 */
std::optional<std::string> getLicense();
}

#endif // VERSION_HPP

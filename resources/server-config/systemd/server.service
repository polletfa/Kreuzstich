[Unit]
Description=Server
Requires=docker.service
After=docker.service

[Service]
Type=simple
WorkingDirectory=/srv/
Environment=ENVIRONMENT=production
ExecStart=/usr/bin/docker compose up
ExecStop=/usr/bin/docker compose down
Restart=always
RestartSec=10s
User=server-manager
Group=docker

[Install]
WantedBy=multi-user.target
